  "item": [
    {
      "name": "Admin Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "x-admin-setup-key",
            "value": "{{admin_setup_key}}",
            "type": "text",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/register",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        },
        "description": "Creates a new admin. In local/non-production, the x-admin-setup-key header is not required. In production, enable that header and set {{admin_setup_key}}."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"Registration succeeded\", function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.token).to.be.a(\"string\");",
              "});",
              "",
              "if (json.token) {",
              "  pm.collectionVariables.set(\"auth_token\", json.token);",
              "}",
              "",
              "if (json.admin) {",
              "  pm.collectionVariables.set(\"admin_id\", String(json.admin.id || \"\"));",
              "  pm.collectionVariables.set(\"admin_email\", json.admin.email || \"\");",
              "  pm.collectionVariables.set(\"admin_name\", json.admin.name || \"\");",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        },
        "description": "Authenticates an admin and returns a JWT token plus admin profile."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test(\"Login succeeded\", function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.message).to.eql(\"Login successful\");",
              "  pm.expect(json.token).to.be.a(\"string\");",
              "});",
              "",
              "if (json.token) {",
              "  pm.collectionVariables.set(\"auth_token\", json.token);",
              "}",
              "",
              "if (json.admin) {",
              "  pm.collectionVariables.set(\"admin_id\", String(json.admin.id || \"\"));",
              "  pm.collectionVariables.set(\"admin_email\", json.admin.email || \"\");",
              "  pm.collectionVariables.set(\"admin_name\", json.admin.name || \"\");",
              "}",
              "",
              "pm.collectionVariables.set(\"authorization_header\", \"Bearer \" + (json.token || \"\"));"
            ]
          }
        }
      ]
    },
